rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isSignedIn() {
      return request.auth != null &&
             request.auth.token.email_verified == true;
    }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidEmail(email) {
      return email is string && email.size() > 0 && email.size() <= 200;
    }

    function isValidUserCreate(data, userId) {
      return data.keys().hasOnly(['email', 'createdAt']) &&
             isValidEmail(data.email) &&
             data.createdAt == request.time &&
             isValidId(userId);
    }

    function isValidExpectedMinutes(value) {
      return value is int && value >= 1 && value <= 1440;
    }

    function isValidUserSettings(data, userId) {
      return data.keys().hasOnly(['userId', 'expectedMinutes', 'requireLocation', 'updatedAt']) &&
             data.userId == userId &&
             isValidExpectedMinutes(data.expectedMinutes) &&
             data.requireLocation is bool &&
             data.updatedAt == request.time;
    }

    function isValidPunchType(value) {
      return value is string && value in ['in', 'out'];
    }

    function isValidPunch(data, userId) {
      return data.keys().hasOnly(['userId', 'timestamp', 'type']) &&
             data.userId == userId &&
             data.timestamp is timestamp &&
             isValidPunchType(data.type);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserCreate(incoming(), userId);
      allow update: if false;
      allow delete: if false;
    }

    match /userSettings/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId) &&
                  isValidId(userId) &&
                  resource.data.userId == request.auth.uid;
      allow create: if isOwner(userId) &&
                    isValidId(userId) &&
                    isValidUserSettings(incoming(), userId);
      allow update: if isOwner(userId) &&
                    isValidId(userId) &&
                    isValidUserSettings(incoming(), userId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['expectedMinutes', 'requireLocation', 'updatedAt']);
      allow delete: if false;
    }

    match /users/{userId}/punches/{punchId} {
      allow get: if isOwner(userId) &&
                 isValidId(userId) &&
                 isValidId(punchId) &&
                 resource.data.userId == request.auth.uid;
      allow list: if isOwner(userId) &&
                  isValidId(userId) &&
                  resource.data.userId == request.auth.uid;
      allow create: if isOwner(userId) &&
                    isValidId(userId) &&
                    isValidId(punchId) &&
                    isValidPunch(incoming(), userId) &&
                    incoming().timestamp == request.time;
      allow update: if isOwner(userId) &&
                    isValidId(userId) &&
                    isValidId(punchId) &&
                    isValidPunch(incoming(), userId) &&
                    incoming().type == existing().type &&
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['timestamp']);
      allow delete: if isOwner(userId) &&
                    isValidId(userId) &&
                    isValidId(punchId) &&
                    resource.data.userId == request.auth.uid;
    }

  }
}
