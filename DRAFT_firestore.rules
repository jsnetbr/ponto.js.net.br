rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // In dev environment some Google sign-ins can occasionally have email_verified missing or false, 
    // but the prompt mandates: "you MUST strictly mandate that the user is verified using request.auth.token.email_verified == true"
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string
        && data.email.size() <= 200
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserCreate(incoming());
      allow update: if false; // Immutable profile
      allow delete: if false;
    }

    function isValidUserSettingsCreate(data) {
       return data.keys().hasAll(['userId', 'expectedHours', 'requireLocation', 'updatedAt'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.expectedHours is number
        && data.expectedHours >= 0 && data.expectedHours <= 24
        && data.requireLocation is bool
        && data.updatedAt == request.time;
    }

    function isValidUserSettingsUpdate(data) {
       return data.expectedHours is number
        && data.expectedHours >= 0 && data.expectedHours <= 24
        && data.requireLocation is bool
        && data.updatedAt == request.time;
    }

    match /userSettings/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserSettingsCreate(incoming());
      allow update: if (
        isOwner(userId) && isValidId(userId) && 
        isValidUserSettingsUpdate(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['expectedHours', 'requireLocation', 'updatedAt'])
      );
    }

    function isValidPunchCreate(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'type'])
        && data.keys().size() == 3
        && data.userId == request.auth.uid
        && data.timestamp == request.time
        && data.type is string
        && data.type.size() <= 3
        && data.type in ['in', 'out'];
    }

    match /users/{userId}/punches/{punchId} {
      allow get: if isOwner(userId) && isValidId(userId) && isValidId(punchId);
      allow list: if isOwner(userId) && isValidId(userId) && resource.data.userId == request.auth.uid; 
      allow create: if isOwner(userId) && isValidId(userId) && isValidId(punchId) && isValidPunchCreate(incoming());
      allow update: if false; // Punches are immutable
      allow delete: if false; // Punches are immutable
    }

  }
}
